{
	"name": "pi-thread-manager",
	"version": "0.1.0",
	"description": "Pi extension for daemon-backed long-lived Pi thread sessions.",
	"type": "module",
	"main": "src/index.ts",
	"exports": "./src/index.ts",
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "node --import tsx --test tests/*.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"threads",
		"rpc"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "0.79.1"
	},
	"dependencies": {
		"tsx": "4.20.5"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.79.1",
		"@types/node": "24.5.2",
		"typescript": "5.9.2"
	},
	"license": "MIT",
	"packageManager": "pnpm@10.30.1",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jastro-dev/pi-thread-manager.git"
	},
	"homepage": "https://github.com/jastro-dev/pi-thread-manager#readme",
	"bugs": {
		"url": "https://github.com/jastro-dev/pi-thread-manager/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
